{
  "name": "pawdetect",
  "version": "1.0.0",
  "private": true,
  "description": "PawDetect — Cat and Dog image classification PWA using TensorFlow.js",
  "scripts": {
    "clean": "node scripts/clean-next.mjs",
    "dev": "node --max-old-space-size=8192 ./node_modules/next/dist/bin/next dev",
    "dev:clean": "npm run clean && npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "icons": "node scripts/generate-icons.mjs",
    "train:model": "node scripts/train-export-tfjs.mjs",
    "export:model": "node scripts/export-initial-model.mjs",
    "postinstall": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@tensorflow-models/mobilenet": "^2.1.1",
    "@tensorflow/tfjs": "^4.22.0",
    "next": "^15.3.2",
    "next-pwa": "^5.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.3.2",
    "postcss": "^8.5.3",
    "sharp": "^0.34.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "optionalDependencies": {
    "@tensorflow/tfjs-node": "^4.22.0"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
